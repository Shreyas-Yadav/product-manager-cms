# AWS ECR registry URI (e.g. 123456789012.dkr.ecr.us-east-1.amazonaws.com)
ECR_REGISTRY=

# AWS RDS MySQL endpoint (e.g. mydb.xxxx.us-east-1.rds.amazonaws.com)
RDS_ENDPOINT=

# Database credentials (must match RDS configuration)
DB_USER=admin
DB_PASSWORD=

# Frontend API URL — baked into the React bundle at docker build time
# Must be your EC2 domain or public IP (NOT localhost)
VITE_API_URL=https://YOUR_DOMAIN
